# PeixotoClaw: Industrial & Private Gitignore

# Privacy: Personal Projects MUST NOT be uploaded
/projects/
!/projects/.gitkeep

# Archival & References (Not used in core)
/references/get-shit-done/
/vendor/EvoSkill/
/references/*.rar
/references/*.zip
/references/*.7z

# Runtime & Dependencies
node_modules/
**/node_modules/
dist/
**/dist/
build/
.next/
out/
temp/
tmp/
logs/
*.log

# Rulebook - ignore runtime data, keep specs and tasks
/.rulebook/*
!/.rulebook/specs/
!/.rulebook/tasks/
!/.rulebook/tasks/**/*.md
!/.rulebook/rulebook.json

# PeixotoClaw Specifics
.agents/brain/
.agents/memories/
**/.antigravity/
*.png
*.jpg
*.jpeg
*.pdf

# Security & Secrets
.env
.env.*
*.pem
*.key

# OS/System
.DS_Store
Thumbs.db
desktop.ini
